{
  "name": "civcardgame",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:integration": "vitest run integration.test",
    "seed-save": "node scripts/bundle.mjs && node scripts/.bundle/seed-save.mjs",
    "sim": "node scripts/bundle.mjs && node scripts/.bundle/sim.mjs",
    "sim:profile": "node scripts/bundle.mjs && npx -y @platformatic/flame@1.7.0 run --delay=none --md-format=detailed scripts/.bundle/sim.mjs --",
    "economy": "node scripts/bundle.mjs && node scripts/.bundle/economy.mjs"
  },
  "dependencies": {
    "pure-rand": "^8.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
